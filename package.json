{
  "name": "expo-router-starter-kit",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "description": "A production-inspired Expo Router starter kit with clean routing, feature modules, reusable UI, theme tokens, i18n, mock auth, and infrastructure examples.",
  "author": "Code with Nomi",
  "license": "MIT",
  "dependencies": {
    "@expo/ui": "~56.0.21",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.15",
    "expo-build-properties": "~56.0.22",
    "expo-constants": "~56.0.19",
    "expo-dev-client": "~56.0.22",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.15",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.14",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.21",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "sonner-native": "^0.26.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "babel-preset-expo": "~56.0.17",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.5",
    "lint-staged": "^17.0.8",
    "metro-minify-terser": "^0.86.0",
    "prettier": "^3.9.4",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run lint",
    "prepare": "husky",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:commit": "commitlint --edit",
    "test": "jest --watch --coverage=false --changedSince=origin/main",
    "testDebug": "jest -o --watch --coverage=false",
    "testFinal": "jest",
    "updateSnapshots": "jest -u --coverage=false"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*": [
      "prettier --write --ignore-unknown"
    ]
  },
  "private": true
}
