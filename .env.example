# ─────────────────────────────────────────────────────────────────────────────
# App Environment
# ─────────────────────────────────────────────────────────────────────────────
# Controls which environment profile is active.
# Values: development | staging | production
APP_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Bundle IDs / Android Package Names
# ─────────────────────────────────────────────────────────────────────────────
# These are your unique app identifiers on the App Store and Play Store.
# Keep them out of version control — add your real values to .env (gitignored).
# Convention: use a .dev / .staging suffix so all variants can be installed
# side-by-side on a device.
BUNDLE_ID_DEV=com.yourcompany.yourapp.dev
BUNDLE_ID_STAGING=com.yourcompany.yourapp.staging
BUNDLE_ID_PROD=com.yourcompany.yourapp

# ─────────────────────────────────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────────────────────────────────
# Leave empty to use the per-environment default in src/config/app-env.ts
API_BASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Feature Flags (build-time overrides)
# ─────────────────────────────────────────────────────────────────────────────
ANALYTICS_ENABLED=false
NOTIFICATIONS_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# EAS
# ─────────────────────────────────────────────────────────────────────────────
# Find this in https://expo.dev → your project → settings
EXPO_PUBLIC_EAS_PROJECT_ID= 
